# ══════════════════════════════════════════════════════════════
# ~/.config/systemd/user/dotfiles-sync.timer
# ══════════════════════════════════════════════════════════════
# Drop this file at:  ~/.config/systemd/user/dotfiles-sync.timer
# ──────────────────────────────────────────────────────────────
[Unit]
Description=Run dotfiles-sync every hour

[Timer]
OnBootSec=2min
OnUnitActiveSec=1h
Persistent=true

[Install]
WantedBy=timers.target
